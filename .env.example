## Oracle APEX connection (for Playwright automation)
# Use FULL URL to the login page of the APEX app you use for admin.
APEX_LOGIN_URL="https://YOUR-APEX-HOST/ords/f?p=YOUR_APP:LOGIN"

# Workspace + credentials used to login
APEX_WORKSPACE="YOUR_WORKSPACE"
APEX_USERNAME="ADMIN_USERNAME"
APEX_PASSWORD="ADMIN_PASSWORD"

## Task-specific pages (set these to the exact pages in your APEX admin app)
# These URLs should be reachable after login.
APEX_CREATE_USER_URL="https://YOUR-APEX-HOST/ords/f?p=YOUR_APP:CREATE_USER"
APEX_UNLOCK_USER_URL="https://YOUR-APEX-HOST/ords/f?p=YOUR_APP:UNLOCK_USER"
APEX_CHANGE_PASSWORD_URL="https://YOUR-APEX-HOST/ords/f?p=YOUR_APP:CHANGE_PASSWORD"

## Inputs for the actions
APEX_NEW_USER_USERNAME="new.user"
APEX_NEW_USER_EMAIL="new.user@example.com"
APEX_NEW_USER_PASSWORD="TempPass123!"

APEX_TARGET_USERNAME="existing.user"
APEX_TARGET_NEW_PASSWORD="NewPass123!"

