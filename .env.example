# Copy to .env and fill in locally. Never commit .env.

# --- Playwright / APEX UI (browser automation) ---
APEX_LOGIN_URL=https://your-workspace.apex.oraclecloud.com/apex/f?p=4550:1
APEX_WORKSPACE=COMAGOL
APEX_USERNAME=
APEX_PASSWORD=

# --- SQLcl / OCI database (CLI — password stored in ~/.dbtools as OCI_DB) ---
# Agent and scripts use: sql -S -name OCI_DB
SQLCL_CONNECTION=OCI_DB
TNS_ADMIN=$HOME/wallet/ociadb
APEX_APP_ID=

# Optional Playwright task inputs (see .cursor/skills/SKILL.md)
# APEX_NEW_USER_USERNAME=
# APEX_NEW_USER_EMAIL=
# APEX_NEW_USER_PASSWORD=
# APEX_TARGET_USERNAME=
# APEX_TARGET_NEW_PASSWORD=
# APEX_APP_NAME=
# APEX_PAGE_NAME=
# APEX_TABLE_NAME=
