authentication xx-custom-auth (
    name: XX Custom Authentication
    type: customAuthentication
    settings {
        authenticationFunction: apex_app_authenticate
    }
    sessionNotValid {
        redirectUrl: f?p=&APP_ID.:9999:&APP_SESSION.::&DEBUG.:::
    }
    logoutUrl: f?p=&APP_ID.:9999:&APP_SESSION.::&DEBUG.:::
)
